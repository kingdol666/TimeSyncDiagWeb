# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── 依赖 ──
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── 测试 ──
/coverage

# ── Next.js 构建 ──
/.next/
/out/

# ── 产出 ──
/build

# ── 操作系统 ──
.DS_Store
*.pem
Thumbs.db

# ── 调试日志 ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── 环境变量 ──
.env
.env.local
.env.*.local

# ── vercel ──
.vercel

# ── TypeScript ──
*.tsbuildinfo
next-env.d.ts

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo
*~

# Build cache
.next/
